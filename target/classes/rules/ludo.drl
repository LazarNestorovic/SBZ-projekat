package rules;

import com.ludo.model.Figura;
import com.ludo.model.StatusFigure;
import com.ludo.model.IshodKocke;
import com.ludo.model.Potez;
import com.ludo.model.StanjeIgre;
import com.ludo.model.StatistikaIgraca;
import com.ludo.util.BoardUtils;

// ============================================================
// NIVO 1 — INICIJACIJA
// Provjera vrijednosti kocke i dostupnih akcija (salience 100-80)
// ============================================================

// Tabela 4: Tri uzastopne sestice — igrac gubi potez i ne pomjera niti jednu figuru
rule "Tri uzastopne sestice - igrac gubi potez"
    salience 100
when
    $kocka  : IshodKocke( uzastopneSestice >= 3 )
    $stanje : StanjeIgre( preskaciPotez == false )
then
    System.out.println("[PRAVILO] Tri uzastopne sestice! Igrac " +
        $stanje.getAktivniIgracId() + " gubi potez.");
    modify( $stanje ) {
        setPreskaciPotez( true ),
        setOdabraniRazlog( "Tri uzastopne sestice - igrac gubi potez" )
    }
end

// Tabela 1: Kocka != 6 i sve figure u bazi -> preskaci potez (nema dostupnih poteza)
rule "Sve figure u bazi bez sestice - preskaci potez"
    salience 95
when
    $kocka  : IshodKocke( vrijednost != 6 )
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    not Figura( vlasnikId == $pid,
                status == StatusFigure.AKTIVNA )
    not Figura( vlasnikId == $pid,
                status == StatusFigure.FINALNA_STAZA )
then
    System.out.println("[PRAVILO] Igrac " + $pid +
        " nema aktivnih figura i kocka nije 6 - preskaci potez.");
    modify( $stanje ) {
        setPreskaciPotez( true ),
        setOdabraniRazlog( "Nema aktivnih figura i kocka nije 6" )
    }
end

// Tabela 4: Bacanje sestice daje bonus roll (ali ne treci uzastopni)
rule "Sestica daje bonus roll"
    salience 90
    no-loop true
when
    $kocka  : IshodKocke( vrijednost == 6, uzastopneSestice < 3 )
    $stanje : StanjeIgre( preskaciPotez == false, bonusRoll == false )
then
    System.out.println("[PRAVILO] Sestica! Igrac " +
        $stanje.getAktivniIgracId() + " dobija bonus roll.");
    modify( $stanje ) { setBonusRoll( true ) }
end

// ============================================================
// NIVO 2 — GENERISANJE KANDIDAT POTEZA (salience 80-60)
// Generisanje svih mogucih poteza kao fakti u radnoj memoriji
// ============================================================

// Tabela 1: Kocka = 6 → uvedi novu figuru iz baze na startnu poziciju
// Uslov: startna pozicija nije blokirana sopstvenom blokadom (>= 2 sopstvene figure)
rule "Kandidat: Uvedi figuru iz baze"
    salience 80
when
    $kocka  : IshodKocke( vrijednost == 6, uzastopneSestice < 3 )
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $figura : Figura( vlasnikId == $pid, status == StatusFigure.BAZA )
    // Prebroji sopstvene figure na startnoj poziciji - mora biti < 2
    $brNaStart : Long() from accumulate(
        $sf : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == BoardUtils.getPocetnaPoziciju( $pid ) ),
        count( $sf )
    )
    eval( $brNaStart < 2 )
then
    int startAbs = BoardUtils.getPocetnaPoziciju( $pid );
    Potez potez = new Potez();
    potez.setFiguraId( $figura.getId() );
    potez.setVlasnikId( $pid );
    potez.setNovaRelativnaPozicija( 1 );
    potez.setNovaApsolutnaPozicija( startAbs );
    potez.setNovaFigura( true );
    potez.setValidan( true );
    potez.setRazlog( "Uvedi figuru iz baze na startnu poziciju" );
    insert( potez );
    System.out.println("[KANDIDAT] Uvedi figuru " + $figura.getId() +
        " na poziciju " + startAbs);
end

// Tabela 2: Pomjeri aktivnu figuru po glavnoj tabli ili u finalnoj stazi
rule "Kandidat: Pomjeri aktivnu figuru"
    salience 75
when
    $kocka  : IshodKocke( $dice : vrijednost, uzastopneSestice < 3 )
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $figura : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA,
                      $relPoz : relativnaPozicija )
    // Figura ne smije preci cilj (tacno polje cilja, Tabela 2)
    eval( $relPoz + $dice <= BoardUtils.CILJ )
then
    int novaPoz = $relPoz + $dice;
    int novaAbs = (novaPoz <= 52) ? BoardUtils.relativnaUApsolutnu( $figura.getVlasnikId(), novaPoz ) : 0;

    Potez potez = new Potez();
    potez.setFiguraId( $figura.getId() );
    potez.setVlasnikId( $pid );
    potez.setNovaRelativnaPozicija( novaPoz );
    potez.setNovaApsolutnaPozicija( novaAbs );
    potez.setNovaFigura( false );
    potez.setValidan( true );
    potez.setRazlog( "Pomjeri figuru za " + $dice + " polja" );
    insert( potez );
    System.out.println("[KANDIDAT] Pomjeri figuru " + $figura.getId() +
        ": relPos " + $relPoz + " -> " + novaPoz + " (absPos=" + novaAbs + ")");
end

// ============================================================
// NIVO 2 — VALIDACIJA POTEZA (salience 60-45)
// Provjera dostupnosti polja i oznacavanje nevazecih poteza
// ============================================================

// Tabela 2: Potez preskace cilj (figura mora TACNO stati na polje cilja)
// Ovaj slucaj je sprecen eval uslovom u generisanju, ali ako udje u finalnu stazu prerano:
rule "Validacija: Prekoracenje cilja u finalnoj stazi"
    salience 65
    no-loop true
when
    $kocka  : IshodKocke( $dice : vrijednost )
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $figura : Figura( vlasnikId == $pid,
                      status == StatusFigure.FINALNA_STAZA,
                      $relPoz : relativnaPozicija )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     figuraId == $figura.getId(),
                     novaRelativnaPozicija > BoardUtils.CILJ )
then
    System.out.println("[VALIDACIJA] Figura " + $figura.getId() +
        " ne moze preci cilj - potez nevazeCI.");
    modify( $potez ) {
        setValidan( false ),
        setRazlog( "Figura ne moze preci tacno polje cilja" )
    }
end

// Tabela 3: Potez na blokadu protivnika — nevazeci potez
rule "Validacija: Potez na blokadu protivnika"
    salience 60
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Postoje >= 2 protivnicke figure na ciljnoj poziciji (blokada)
    $brProtivnika : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs ),
        count( $pf )
    )
    eval( $brProtivnika >= 2 )
then
    System.out.println("[VALIDACIJA] Potez nevazeci - blokada protivnika na poziciji " + $targetAbs);
    modify( $potez ) {
        setValidan( false ),
        setRazlog( "Protivnicka blokada na ciljnoj poziciji - potez nevazeci" )
    }
end

// ============================================================
// NIVO 3 — EVALUACIJA KONSEKVENCI (salience 44-30)
// Provjera da li odabrani potez eliminise protivnika, stvara blokadu
// ili premjesta figuru na sigurno polje
// ============================================================

// Tabela 3: Potez eliminise nezasticenu protivnicku figuru (bonus roll)
rule "Evaluacija: Potez eliminise protivnicku figuru"
    salience 44
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     mozeEliminisati == false,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Postoji tacno 1 protivnicka figura na ciljnoj poziciji i nije zasticena
    $brProtivnika : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs,
                      sigurna == false ),
        count( $pf )
    )
    eval( $brProtivnika == 1 )
then
    System.out.println("[EVALUACIJA] Potez figure " + $potez.getFiguraId() +
        " moze eliminisati protivnicku figuru na poziciji " + $targetAbs);
    modify( $potez ) {
        setMozeEliminisati( true ),
        setRazlog( "Eliminacija protivnicke figure na poziciji " + $targetAbs )
    }
end

// Tabela 2 / Evaluacija: Potez vodi na sigurno (zvjezdasto) polje
rule "Evaluacija: Potez vodi na sigurno polje"
    salience 42
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     naSignurnoPlje == false,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    eval( BoardUtils.jeSigurnaPozicija( $pid, $targetAbs ) )
then
    System.out.println("[EVALUACIJA] Potez figure " + $potez.getFiguraId() +
        " vodi na sigurno polje " + $targetAbs);
    modify( $potez ) {
        setNaSignurnoPlje( true ),
        setRazlog( $potez.getRazlog() + " [sigurno polje]" )
    }
end

// Evaluacija: Potez premjesta figuru IZ opasne zone
// (neka protivnicka figura moze doseci trenutnu poziciju nase figure bacanjem 1-6)
rule "Evaluacija: Potez iz opasne zone"
    salience 40
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      izOpasneZone == false, novaFigura == false,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.AKTIVNA, $currAbs : apsolutnaPozicija )
    // Postoji protivnicka figura koja moze doseci trenutnu poziciju nase figure
    $prot    : Figura( vlasnikId != $pid,
                       status == StatusFigure.AKTIVNA, $protAbs : apsolutnaPozicija )
    eval( BoardUtils.jeUDoseguZa( $currAbs, $protAbs ) )
then
    System.out.println("[EVALUACIJA] Figura " + $figId +
        " je u opasnoj zoni (protivnik na " + $prot.getApsolutnaPozicija() + ")");
    modify( $potez ) {
        setIzOpasneZone( true ),
        setRazlog( $potez.getRazlog() + " [bijeg iz opasne zone]" )
    }
end

// Tabela 3: Detekcija kreiranja blokade (2 sopstvene figure na istom polju)
rule "Evaluacija: Potez kreira blokadu"
    salience 38
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Vec postoji tacno 1 sopstvena figura na ciljnoj poziciji
    $brSopstvenih : Long() from accumulate(
        $sf : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs ),
        count( $sf )
    )
    eval( $brSopstvenih == 1 )
then
    System.out.println("[EVALUACIJA] Potez figure " + $potez.getFiguraId() +
        " kreira blokadu na poziciji " + $targetAbs);
    // Blokada je validna - samo biljeZimo
    modify( $potez ) {
        setRazlog( $potez.getRazlog() + " [kreira blokadu]" )
    }
end

// ============================================================
// SEKCIJA 4.2 — PRIORITETNA PRAVILA ODABIRA FIGURE (salience 25-10)
// Postavljanje prioriteta na validne poteze prema specifikaciji
// ============================================================

// Prioritet 1: Eliminisi protivnicku figuru ako je moguce
rule "Prioritet 1: Eliminisi protivnika"
    salience 25
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     mozeEliminisati == true, prioritet > 1 )
then
    modify( $potez ) { setPrioritet( 1 ) }
    System.out.println("[PRIORITET 1] Figura " + $potez.getFiguraId() + " eliminise protivnika");
end

// Prioritet 2: Uvedi novu figuru ako je kocka 6 i ima figura u bazi
rule "Prioritet 2: Uvedi novu figuru"
    salience 24
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaFigura == true, mozeEliminisati == false, prioritet > 2 )
then
    modify( $potez ) { setPrioritet( 2 ) }
    System.out.println("[PRIORITET 2] Uvedi novu figuru " + $potez.getFiguraId());
end

// Prioritet 3: Pomjeri figuru koja je najbliza cilju (finalna staza)
// Primjenjuje se na figure u finalnoj stazi i figure sa najvecim relPos na tabli
rule "Prioritet 3: Najbliza figura cilju - finalna staza"
    salience 23
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      novaFigura == false, prioritet > 3,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.FINALNA_STAZA )
then
    modify( $potez ) { setPrioritet( 3 ) }
    System.out.println("[PRIORITET 3] Figura " + $figId + " u finalnoj stazi - prioritet 3");
end

rule "Prioritet 3: Najbliza figura cilju - po relativnoj poziciji"
    salience 22
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      novaFigura == false, prioritet > 3,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.AKTIVNA, $relPoz : relativnaPozicija )
    // Nema druge aktivne sopstvene figure sa vecim relPos (ova je najbliza)
    not Figura( vlasnikId == $pid,
                status == StatusFigure.AKTIVNA,
                relativnaPozicija > $relPoz )
    not Figura( vlasnikId == $pid, status == StatusFigure.FINALNA_STAZA )
then
    modify( $potez ) { setPrioritet( 3 ) }
    System.out.println("[PRIORITET 3] Figura " + $figId + " je najbliza cilju (relPos=" + $relPoz + ")");
end

// Prioritet 4: Pomjeri figuru iz opasne zone (sljedece polje je protivnik)
rule "Prioritet 4: Bijeg iz opasne zone"
    salience 21
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     izOpasneZone == true, prioritet > 4 )
then
    modify( $potez ) { setPrioritet( 4 ) }
    System.out.println("[PRIORITET 4] Figura " + $potez.getFiguraId() + " bjezi iz opasne zone");
end

// Prioritet 5: Pomjeri figuru na sigurno polje (zvjezdasto polje)
rule "Prioritet 5: Pomjeri na sigurno polje"
    salience 20
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     naSignurnoPlje == true, prioritet > 5 )
then
    modify( $potez ) { setPrioritet( 5 ) }
    System.out.println("[PRIORITET 5] Figura " + $potez.getFiguraId() + " ide na sigurno polje");
end

// Prioritet 6: Pomjeri najdalju figuru od cilja (figuru sa najmanjim relPos)
rule "Prioritet 6: Pomjeri najdalju figuru od cilja"
    salience 19
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      novaFigura == false, prioritet > 6,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.AKTIVNA, $relPoz : relativnaPozicija )
    // Nema druge aktivne sopstvene figure sa manjim relPos
    not Figura( vlasnikId == $pid,
                status == StatusFigure.AKTIVNA,
                relativnaPozicija < $relPoz )
then
    modify( $potez ) { setPrioritet( 6 ) }
    System.out.println("[PRIORITET 6] Figura " + $figId + " je najdalja od cilja");
end

// Prioritet 7: Nasumican validan potez (zadrzava default prioritet 7)
// Pravilo za ispis - svi preostali validni potezi imaju prioritet 7

// ============================================================
// ODABIR FINALNOG POTEZA (salience -10)
// Bira potez sa najvisim prioritetom (najmanji broj prioriteta)
// ============================================================

rule "Odaberi finalni potez sa najvisim prioritetom"
    salience -10
when
    $stanje : StanjeIgre( preskaciPotez == false, odabranaFiguraId == -1, $pid : aktivniIgracId )
    // Odaberi validni potez sa najvisim prioritetom
    $odabrani : Potez( validan == true, vlasnikId == $pid, $bestPrio : prioritet )
    // Nema drugog validnog poteza sa boljim (manjim) prioritetom
    not Potez( validan == true, vlasnikId == $pid, prioritet < $bestPrio )
then
    System.out.println("\n=== ODABRANI POTEZ ===");
    System.out.println("Figura ID  : " + $odabrani.getFiguraId());
    System.out.println("Nova relPos: " + $odabrani.getNovaRelativnaPozicija());
    System.out.println("Nova absPos: " + $odabrani.getNovaApsolutnaPozicija());
    System.out.println("Prioritet  : " + $odabrani.getPrioritet());
    System.out.println("Eliminacija: " + $odabrani.isMozeEliminisati());
    System.out.println("Razlog     : " + $odabrani.getRazlog());
    System.out.println("=====================\n");
    modify( $stanje ) {
        setOdabranaFiguraId( $odabrani.getFiguraId() ),
        setOdabranaPozicija( $odabrani.getNovaRelativnaPozicija() ),
        setOdabraniRazlog( $odabrani.getRazlog() )
    }
end

// Ispis ako igrac preskace potez
rule "Ispis: Igrac preskace potez"
    salience -10
when
    $stanje : StanjeIgre( preskaciPotez == true )
then
    System.out.println("\n=== POTEZ PRESKOCEN ===");
    System.out.println("Igrac " + $stanje.getAktivniIgracId() + " preskace potez.");
    System.out.println("Razlog: " + $stanje.getOdabraniRazlog());
    System.out.println("=======================\n");
end
