package rules;

import com.ludo.model.Figura;
import com.ludo.model.StatusFigure;
import com.ludo.model.IshodKocke;
import com.ludo.model.Potez;
import com.ludo.model.StanjeIgre;
import com.ludo.model.StatistikaIgraca;
import com.ludo.model.ModusIgre;
import com.ludo.model.DogadjajIgre;
import com.ludo.model.DogadjajIgre.TipDogadjaja;
import com.ludo.util.BoardUtils;

// DogadjajIgre deklarisan kao CEP event sa timestamp poljem za STREAM mod obrade
declare DogadjajIgre
    @role( event )
    @timestamp( timestamp )
end

// ============================================================
// NIVO 1 — INICIJACIJA
// Provjera vrijednosti kocke i dostupnih akcija (salience 100-80)
// ============================================================

// Tabela 4: Tri uzastopne sestice — igrac gubi potez i ne pomjera niti jednu figuru
rule "Tri uzastopne sestice - igrac gubi potez"
    salience 100
when
    $kocka  : IshodKocke( uzastopneSestice >= 3 )
    $stanje : StanjeIgre( preskaciPotez == false )
then
    System.out.println("[PRAVILO] Tri uzastopne sestice! Igrac " +
        $stanje.getAktivniIgracId() + " gubi potez.");
    modify( $stanje ) {
        setPreskaciPotez( true ),
        setOdabraniRazlog( "Tri uzastopne sestice - igrac gubi potez" )
    }
end

// Tabela 1: Kocka != 6 i sve figure u bazi -> preskaci potez (nema dostupnih poteza)
rule "Sve figure u bazi bez sestice - preskaci potez"
    salience 95
when
    $kocka  : IshodKocke( vrijednost != 6 )
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    not Figura( vlasnikId == $pid,
                status == StatusFigure.AKTIVNA )
    not Figura( vlasnikId == $pid,
                status == StatusFigure.FINALNA_STAZA )
then
    System.out.println("[PRAVILO] Igrac " + $pid +
        " nema aktivnih figura i kocka nije 6 - preskaci potez.");
    modify( $stanje ) {
        setPreskaciPotez( true ),
        setOdabraniRazlog( "Nema aktivnih figura i kocka nije 6" )
    }
end

// Tabela 4: Bacanje sestice daje bonus roll (ali ne treci uzastopni)
rule "Sestica daje bonus roll"
    salience 90
    no-loop true
when
    $kocka  : IshodKocke( vrijednost == 6, uzastopneSestice < 3 )
    $stanje : StanjeIgre( preskaciPotez == false, bonusRoll == false )
then
    System.out.println("[PRAVILO] Sestica! Igrac " +
        $stanje.getAktivniIgracId() + " dobija bonus roll.");
    modify( $stanje ) { setBonusRoll( true ) }
end

// ============================================================
// SEKCIJA 4.3 — DETEKCIJA MODUSA IGRE (salience 85-83)
// Fires after Level 1 (salience 100-90) and before Level 2 (salience 80).
// Mod se postavlja jednom po sesiji; modify($stanje) onemogucava dalje aktivacije
// jer uvjet modus == ModusIgre.NEUTRALNI vise nije ispunjen.
// ============================================================

// Agresivni modus: protivnik ima >= 3 figure na tabli I >= 1 figuru blizu cilja (< 10 polja)
rule "Modus: Agresivni"
    salience 85
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, modus == ModusIgre.NEUTRALNI, $pid : aktivniIgracId )
    // Broj protivnickih figura na glavnoj tabli
    $brNaTabli : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid, status == StatusFigure.AKTIVNA ),
        count( $pf )
    )
    eval( $brNaTabli >= 3 )
    // Najmanje jedna protivnicka figura unutar 10 polja od cilja (relPos >= 49)
    exists Figura( vlasnikId != $pid,
                   status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA,
                   relativnaPozicija >= 49 )
then
    modify( $stanje ) { setModus( ModusIgre.AGRESIVNI ) }
    System.out.println("[MODUS] Agresivni modus! Protivnik ima " + $brNaTabli + " figura i jedna je blizu cilja.");
end

// Defanzivni modus: igrac ima <= 1 figuru na tabli (izlozena pozicija)
rule "Modus: Defanzivni - malo figura"
    salience 84
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, modus == ModusIgre.NEUTRALNI, $pid : aktivniIgracId )
    $brNase : Long() from accumulate(
        $f : Figura( vlasnikId == $pid, status == StatusFigure.AKTIVNA ),
        count( $f )
    )
    eval( $brNase <= 1 )
then
    modify( $stanje ) { setModus( ModusIgre.DEFANZIVNI ) }
    System.out.println("[MODUS] Defanzivni modus! Igrac " + $pid + " ima samo " + $brNase + " figuru na tabli.");
end

// Defanzivni modus: neka nasa nezasticena figura je u dosegu protivnika
rule "Modus: Defanzivni - figura ugrozena"
    salience 83
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, modus == ModusIgre.NEUTRALNI, $pid : aktivniIgracId )
    $nase   : Figura( vlasnikId == $pid, status == StatusFigure.AKTIVNA,
                      sigurna == false, $nasAbs : apsolutnaPozicija )
    exists Figura( vlasnikId != $pid, status == StatusFigure.AKTIVNA,
                   $protAbs : apsolutnaPozicija,
                   eval( BoardUtils.jeUDoseguZa( $nasAbs, $protAbs ) ) )
then
    modify( $stanje ) { setModus( ModusIgre.DEFANZIVNI ) }
    System.out.println("[MODUS] Defanzivni modus! Figura " + $nase.getId() +
        " igraca " + $pid + " ugrozena na poziciji " + $nasAbs + ".");
end

// Prioritetna prilagodba u AGRESIVNOM modusu (salience 27 — prije standardnih prioriteta na 25-10):
// Prihvatamo veci rizik — bijeg iz opasne zone se demotira na prioritet 5
rule "Modus Agresivni: prihvati rizik, smanji prioritet bijega"
    salience 27
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, modus == ModusIgre.AGRESIVNI, $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid, izOpasneZone == true, prioritet == 4 )
then
    modify( $potez ) { setPrioritet( 5 ) }
    System.out.println("[MODUS AGRESIVNI] Bijeg figure " + $potez.getFiguraId() +
        " iz opasne zone demotiran na prioritet 5 (agresivan pristup).");
end

// Prioritetna prilagodba u DEFANZIVNOM modusu (salience 27):
// Svaki potez na sigurno polje postaje prioritet 2
rule "Modus Defanzivni: sigurno polje prioritet 2"
    salience 27
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, modus == ModusIgre.DEFANZIVNI, $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid, naSignurnoPlje == true, prioritet > 2 )
then
    modify( $potez ) { setPrioritet( 2 ) }
    System.out.println("[MODUS DEFANZIVNI] Figura " + $potez.getFiguraId() +
        " ide na sigurno polje -> prioritet 2.");
end

// ============================================================
// NIVO 2 — GENERISANJE KANDIDAT POTEZA (salience 80-60)
// Generisanje svih mogucih poteza kao fakti u radnoj memoriji
// ============================================================

// Tabela 1: Kocka = 6 → uvedi novu figuru iz baze na startnu poziciju
// Uslov: startna pozicija nije blokirana sopstvenom blokadom (>= 2 sopstvene figure)
rule "Kandidat: Uvedi figuru iz baze"
    salience 80
when
    $kocka  : IshodKocke( vrijednost == 6, uzastopneSestice < 3 )
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $figura : Figura( vlasnikId == $pid, status == StatusFigure.BAZA )
    // Prebroji sopstvene figure na startnoj poziciji - mora biti < 2
    $brNaStart : Long() from accumulate(
        $sf : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == BoardUtils.getPocetnaPoziciju( $pid ) ),
        count( $sf )
    )
    eval( $brNaStart < 2 )
then
    int startAbs = BoardUtils.getPocetnaPoziciju( $pid );
    Potez potez = new Potez();
    potez.setFiguraId( $figura.getId() );
    potez.setVlasnikId( $pid );
    potez.setNovaRelativnaPozicija( 1 );
    potez.setNovaApsolutnaPozicija( startAbs );
    potez.setNovaFigura( true );
    potez.setValidan( true );
    potez.setRazlog( "Uvedi figuru iz baze na startnu poziciju" );
    insert( potez );
    System.out.println("[KANDIDAT] Uvedi figuru " + $figura.getId() +
        " na poziciju " + startAbs);
end

// Tabela 2: Pomjeri aktivnu figuru po glavnoj tabli ili u finalnoj stazi
rule "Kandidat: Pomjeri aktivnu figuru"
    salience 75
when
    $kocka  : IshodKocke( $dice : vrijednost, uzastopneSestice < 3 )
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $figura : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA,
                      $relPoz : relativnaPozicija )
    // Figura ne smije preci cilj (tacno polje cilja, Tabela 2)
    eval( $relPoz + $dice <= BoardUtils.CILJ )
then
    int novaPoz = $relPoz + $dice;
    int novaAbs = (novaPoz <= 52) ? BoardUtils.relativnaUApsolutnu( $figura.getVlasnikId(), novaPoz ) : 0;

    Potez potez = new Potez();
    potez.setFiguraId( $figura.getId() );
    potez.setVlasnikId( $pid );
    potez.setNovaRelativnaPozicija( novaPoz );
    potez.setNovaApsolutnaPozicija( novaAbs );
    potez.setNovaFigura( false );
    potez.setValidan( true );
    potez.setRazlog( "Pomjeri figuru za " + $dice + " polja" );
    insert( potez );
    System.out.println("[KANDIDAT] Pomjeri figuru " + $figura.getId() +
        ": relPos " + $relPoz + " -> " + novaPoz + " (absPos=" + novaAbs + ")");
end

// ============================================================
// NIVO 2 — VALIDACIJA POTEZA (salience 60-45)
// Provjera dostupnosti polja i oznacavanje nevazecih poteza
// ============================================================

// Tabela 2: Potez preskace cilj (figura mora TACNO stati na polje cilja)
// Ovaj slucaj je sprecen eval uslovom u generisanju, ali ako udje u finalnu stazu prerano:
rule "Validacija: Prekoracenje cilja u finalnoj stazi"
    salience 65
    no-loop true
when
    $kocka  : IshodKocke( $dice : vrijednost )
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $figura : Figura( vlasnikId == $pid,
                      status == StatusFigure.FINALNA_STAZA,
                      $relPoz : relativnaPozicija )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     figuraId == $figura.getId(),
                     novaRelativnaPozicija > BoardUtils.CILJ )
then
    System.out.println("[VALIDACIJA] Figura " + $figura.getId() +
        " ne moze preci cilj - potez nevazeCI.");
    modify( $potez ) {
        setValidan( false ),
        setRazlog( "Figura ne moze preci tacno polje cilja" )
    }
end

// Tabela 3: Potez na blokadu protivnika — nevazeci potez
rule "Validacija: Potez na blokadu protivnika"
    salience 60
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Postoje >= 2 protivnicke figure na ciljnoj poziciji (blokada)
    $brProtivnika : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs ),
        count( $pf )
    )
    eval( $brProtivnika >= 2 )
then
    System.out.println("[VALIDACIJA] Potez nevazeci - blokada protivnika na poziciji " + $targetAbs);
    modify( $potez ) {
        setValidan( false ),
        setRazlog( "Protivnicka blokada na ciljnoj poziciji - potez nevazeci" )
    }
end

// ============================================================
// NIVO 3 — EVALUACIJA KONSEKVENCI (salience 44-30)
// Provjera da li odabrani potez eliminise protivnika, stvara blokadu
// ili premjesta figuru na sigurno polje
// ============================================================

// Tabela 3: Potez eliminise nezasticenu protivnicku figuru (bonus roll)
rule "Evaluacija: Potez eliminise protivnicku figuru"
    salience 44
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     mozeEliminisati == false,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Postoji tacno 1 protivnicka figura na ciljnoj poziciji i nije zasticena
    $brProtivnika : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs,
                      sigurna == false ),
        count( $pf )
    )
    eval( $brProtivnika == 1 )
then
    System.out.println("[EVALUACIJA] Potez figure " + $potez.getFiguraId() +
        " moze eliminisati protivnicku figuru na poziciji " + $targetAbs);
    modify( $potez ) {
        setMozeEliminisati( true ),
        setRazlog( "Eliminacija protivnicke figure na poziciji " + $targetAbs )
    }
end

// Tabela 2 / Evaluacija: Potez vodi na sigurno (zvjezdasto) polje
rule "Evaluacija: Potez vodi na sigurno polje"
    salience 42
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     naSignurnoPlje == false,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    eval( BoardUtils.jeSigurnaPozicija( $pid, $targetAbs ) )
then
    System.out.println("[EVALUACIJA] Potez figure " + $potez.getFiguraId() +
        " vodi na sigurno polje " + $targetAbs);
    modify( $potez ) {
        setNaSignurnoPlje( true ),
        setRazlog( $potez.getRazlog() + " [sigurno polje]" )
    }
end

// Evaluacija: Potez premjesta figuru IZ opasne zone
// (neka protivnicka figura moze doseci trenutnu poziciju nase figure bacanjem 1-6)
rule "Evaluacija: Potez iz opasne zone"
    salience 40
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      izOpasneZone == false, novaFigura == false,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.AKTIVNA, $currAbs : apsolutnaPozicija )
    // Postoji protivnicka figura koja moze doseci trenutnu poziciju nase figure
    $prot    : Figura( vlasnikId != $pid,
                       status == StatusFigure.AKTIVNA, $protAbs : apsolutnaPozicija )
    eval( BoardUtils.jeUDoseguZa( $currAbs, $protAbs ) )
then
    System.out.println("[EVALUACIJA] Figura " + $figId +
        " je u opasnoj zoni (protivnik na " + $prot.getApsolutnaPozicija() + ")");
    modify( $potez ) {
        setIzOpasneZone( true ),
        setRazlog( $potez.getRazlog() + " [bijeg iz opasne zone]" )
    }
end

// Tabela 3: Detekcija kreiranja blokade (2 sopstvene figure na istom polju)
rule "Evaluacija: Potez kreira blokadu"
    salience 38
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Vec postoji tacno 1 sopstvena figura na ciljnoj poziciji
    $brSopstvenih : Long() from accumulate(
        $sf : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs ),
        count( $sf )
    )
    eval( $brSopstvenih == 1 )
then
    System.out.println("[EVALUACIJA] Potez figure " + $potez.getFiguraId() +
        " kreira blokadu na poziciji " + $targetAbs);
    // Blokada je validna - samo biljeZimo
    modify( $potez ) {
        setRazlog( $potez.getRazlog() + " [kreira blokadu]" )
    }
end

// ============================================================
// SEKCIJA 4.2 — PRIORITETNA PRAVILA ODABIRA FIGURE (salience 25-10)
// Postavljanje prioriteta na validne poteze prema specifikaciji
// ============================================================

// Prioritet 1: Eliminisi protivnicku figuru ako je moguce
rule "Prioritet 1: Eliminisi protivnika"
    salience 25
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     mozeEliminisati == true, prioritet > 1 )
then
    modify( $potez ) { setPrioritet( 1 ) }
    System.out.println("[PRIORITET 1] Figura " + $potez.getFiguraId() + " eliminise protivnika");
end

// Prioritet 2: Uvedi novu figuru ako je kocka 6 i ima figura u bazi
rule "Prioritet 2: Uvedi novu figuru"
    salience 24
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaFigura == true, mozeEliminisati == false, prioritet > 2 )
then
    modify( $potez ) { setPrioritet( 2 ) }
    System.out.println("[PRIORITET 2] Uvedi novu figuru " + $potez.getFiguraId());
end

// Prioritet 3: Pomjeri figuru koja je najbliza cilju (finalna staza)
// Primjenjuje se na figure u finalnoj stazi i figure sa najvecim relPos na tabli
rule "Prioritet 3: Najbliza figura cilju - finalna staza"
    salience 23
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      novaFigura == false, prioritet > 3,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.FINALNA_STAZA, $relPoz : relativnaPozicija )
    // Nema sopstvene figure na finalnoj stazi sa vecim relPos (ova je najbliza cilju)
    not Figura( vlasnikId == $pid,
                status == StatusFigure.FINALNA_STAZA,
                relativnaPozicija > $relPoz )
then
    modify( $potez ) { setPrioritet( 3 ) }
    System.out.println("[PRIORITET 3] Figura " + $figId + " u finalnoj stazi - prioritet 3");
end

rule "Prioritet 3: Najbliza figura cilju - po relativnoj poziciji"
    salience 22
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      novaFigura == false, prioritet > 3,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.AKTIVNA, $relPoz : relativnaPozicija )
    // Nema druge aktivne sopstvene figure sa vecim relPos (ova je najbliza)
    not Figura( vlasnikId == $pid,
                status == StatusFigure.AKTIVNA,
                relativnaPozicija > $relPoz )
    not Figura( vlasnikId == $pid, status == StatusFigure.FINALNA_STAZA )
then
    modify( $potez ) { setPrioritet( 3 ) }
    System.out.println("[PRIORITET 3] Figura " + $figId + " je najbliza cilju (relPos=" + $relPoz + ")");
end

// Prioritet 4: Pomjeri figuru iz opasne zone (sljedece polje je protivnik)
rule "Prioritet 4: Bijeg iz opasne zone"
    salience 21
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     izOpasneZone == true, prioritet > 4 )
then
    modify( $potez ) { setPrioritet( 4 ) }
    System.out.println("[PRIORITET 4] Figura " + $potez.getFiguraId() + " bjezi iz opasne zone");
end

// Prioritet 5: Pomjeri figuru na sigurno polje (zvjezdasto polje)
rule "Prioritet 5: Pomjeri na sigurno polje"
    salience 20
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     naSignurnoPlje == true, prioritet > 5 )
then
    modify( $potez ) { setPrioritet( 5 ) }
    System.out.println("[PRIORITET 5] Figura " + $potez.getFiguraId() + " ide na sigurno polje");
end

// Prioritet 6: Pomjeri najdalju figuru od cilja (figuru sa najmanjim relPos)
rule "Prioritet 6: Pomjeri najdalju figuru od cilja"
    salience 19
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $potez   : Potez( validan == true, vlasnikId == $pid,
                      novaFigura == false, prioritet > 6,
                      $figId : figuraId )
    $figura  : Figura( id == $figId, vlasnikId == $pid,
                       status == StatusFigure.AKTIVNA, $relPoz : relativnaPozicija )
    // Nema druge aktivne sopstvene figure sa manjim relPos
    not Figura( vlasnikId == $pid,
                status == StatusFigure.AKTIVNA,
                relativnaPozicija < $relPoz )
then
    modify( $potez ) { setPrioritet( 6 ) }
    System.out.println("[PRIORITET 6] Figura " + $figId + " je najdalja od cilja");
end

// Prioritet 7: Nasumican validan potez (zadrzava default prioritet 7)
// Pravilo za ispis - svi preostali validni potezi imaju prioritet 7

// ============================================================
// ODABIR FINALNOG POTEZA (salience -10)
// Bira potez sa najvisim prioritetom (najmanji broj prioriteta)
// ============================================================

rule "Odaberi finalni potez sa najvisim prioritetom"
    salience -10
when
    $stanje : StanjeIgre( preskaciPotez == false, odabranaFiguraId == -1, $pid : aktivniIgracId )
    // Odaberi validni potez sa najvisim prioritetom
    $odabrani : Potez( validan == true, vlasnikId == $pid, $bestPrio : prioritet )
    // Nema drugog validnog poteza sa boljim (manjim) prioritetom
    not Potez( validan == true, vlasnikId == $pid, prioritet < $bestPrio )
then
    System.out.println("\n=== ODABRANI POTEZ ===");
    System.out.println("Figura ID  : " + $odabrani.getFiguraId());
    System.out.println("Nova relPos: " + $odabrani.getNovaRelativnaPozicija());
    System.out.println("Nova absPos: " + $odabrani.getNovaApsolutnaPozicija());
    System.out.println("Prioritet  : " + $odabrani.getPrioritet());
    System.out.println("Eliminacija: " + $odabrani.isMozeEliminisati());
    System.out.println("Razlog     : " + $odabrani.getRazlog());
    System.out.println("=====================\n");
    modify( $stanje ) {
        setOdabranaFiguraId( $odabrani.getFiguraId() ),
        setOdabranaPozicija( $odabrani.getNovaRelativnaPozicija() ),
        setOdabraniRazlog( $odabrani.getRazlog() )
    }
end

// Ispis ako igrac preskace potez
rule "Ispis: Igrac preskace potez"
    salience -10
when
    $stanje : StanjeIgre( preskaciPotez == true )
then
    System.out.println("\n=== POTEZ PRESKOCEN ===");
    System.out.println("Igrac " + $stanje.getAktivniIgracId() + " preskace potez.");
    System.out.println("Razlog: " + $stanje.getOdabraniRazlog());
    System.out.println("=======================\n");
end

// ============================================================
// SEKCIJA 6.3 — NAPREDNA AKUMULACIJA (salience 43)
// Annotira poteze sa gustinom i rizik-skorom prije evaluacije
// ============================================================

// 6.3: Rizik-skor poteza = (1 ako eliminise protivnika) - (broj protivnika koji mogu doseci novu poziciju / 6)
// Visok pozitivan skor = dobar agresivan potez; negativan = riskantan
rule "6.3: Rizik-skor poteza"
    salience 43
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaApsolutnaPozicija > 0, $targetAbs : novaApsolutnaPozicija )
    // Broj protivnickih figura koje mogu doseci novu poziciju nase figure
    $brPrijetnji : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid,
                      status == StatusFigure.AKTIVNA,
                      $protAbs : apsolutnaPozicija,
                      eval( BoardUtils.jeUDoseguZa( $targetAbs, $protAbs ) ) ),
        count( $pf )
    )
then
    double eliminacijaBonus = $potez.isMozeEliminisati() ? 1.0 : 0.0;
    double prijetnjaPenalty  = Math.min( $brPrijetnji, 6 ) / 6.0;
    double skor = eliminacijaBonus - prijetnjaPenalty;
    modify( $potez ) { setRizikSkor( skor ) }
    System.out.println("[6.3] Rizik-skor poteza figure " + $potez.getFiguraId() +
        ": " + String.format("%.2f", skor) +
        " (eliminira=" + $potez.isMozeEliminisati() + ", prijetnje=" + $brPrijetnji + ")");
end

// 6.3: Gustina protivnika u kriticnoj zoni (aps. pozicije 40-52)
// Potez koji odvodi nasu figuru u tu zonu dobija upozorenje u razlogu
rule "6.3: Gustina protivnika u kriticnoj zoni"
    salience 43
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaApsolutnaPozicija >= 40, novaApsolutnaPozicija <= 52 )
    $gustina : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid,
                      status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija >= 40, apsolutnaPozicija <= 52 ),
        count( $pf )
    )
    eval( $gustina >= 2 )
then
    modify( $potez ) {
        setRazlog( $potez.getRazlog() + " [visoka gustina protivnika u kriticnoj zoni: " + $gustina + "]" )
    }
    System.out.println("[6.3] Gustina protivnika u kriticnoj zoni: " + $gustina +
        " figura (potez figure " + $potez.getFiguraId() + ")");
end

// ============================================================
// SEKCIJA 5.3 — PRILAGODBA PRIORITETA NA OSNOVU STATISTIKA (salience 26)
// Fires before Section 4.2 priority rules (salience 25-10)
// ============================================================

// 5.3: Agresivan stil (stilIgreSkor > 0.6) -> eliminacija dobija prioritet 1 bez obzira na modus
rule "5.3: Agresivan stil - eliminacija prioritet 1"
    salience 26
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    StatistikaIgraca( igracId == $pid, stilIgreSkor > 0.6 )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     mozeEliminisati == true, prioritet > 1 )
then
    modify( $potez ) { setPrioritet( 1 ) }
    System.out.println("[5.3] Agresivan stil: eliminacija figure " + $potez.getFiguraId() + " -> prioritet 1");
end

// 5.3: Puno primljenih eliminacija (> 5) -> defanzivno ponasanje: sigurno polje postaje prioritet 2
rule "5.3: Puno eliminacija primljenih - sigurno polje prioritet 2"
    salience 26
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    StatistikaIgraca( igracId == $pid, eliminacijePrimljene > 5 )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     naSignurnoPlje == true, prioritet > 2 )
then
    modify( $potez ) { setPrioritet( 2 ) }
    System.out.println("[5.3] Previse eliminacija primljenih: sigurno polje figure " + $potez.getFiguraId() + " -> prioritet 2");
end

// 5.3: Blizu cilja (prosjecna udaljenost < 8) -> samo potezi ka cilju, ostali idu na prioritet 8
rule "5.3: Blizu cilja - fokus na cilj"
    salience 26
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    StatistikaIgraca( igracId == $pid, prosjUdaljenostOdCilja < 8.0, prosjUdaljenostOdCilja > 0.0 )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     novaFigura == false, prioritet < 8,
                     $figId : figuraId )
    $figura : Figura( id == $figId, vlasnikId == $pid,
                      status != StatusFigure.FINALNA_STAZA )
then
    modify( $potez ) { setPrioritet( 8 ) }
    System.out.println("[5.3] Blizu cilja: potez figure " + $figId + " koji nije ka cilju -> prioritet 8");
end

// 6.3: Historijska analiza - agresivni obrazac
// Ako je igrac eliminisao u > 25% poteza I vec ima figuru u cilju, agresivna taktika radi -> pojaci je
rule "6.3: Historijska analiza - agresivni obrazac"
    salience 26
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $stat   : StatistikaIgraca( igracId == $pid, ukupnoPoteza >= 5, figureUCilju >= 1,
                                eval( $stat.getEliminacijeIzvedene() * 1.0 / $stat.getUkupnoPoteza() > 0.25 ) )
    $potez  : Potez( validan == true, vlasnikId == $pid, mozeEliminisati == true, prioritet > 1 )
then
    modify( $potez ) { setPrioritet( 1 ) }
    System.out.println("[6.3] Historijski agresivni obrazac potvrđen: eliminacija figure " +
        $potez.getFiguraId() + " -> prioritet 1");
end

// 6.3: Historijska analiza - defanzivni obrazac
// Ako je igrac cesto birao sigurna polja (> 40% poteza) I ima figuru u cilju, taktika radi -> pojaci je
rule "6.3: Historijska analiza - defanzivni obrazac"
    salience 26
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    $stat   : StatistikaIgraca( igracId == $pid, ukupnoPoteza >= 5, figureUCilju >= 1,
                                eval( $stat.getPoteziNaSigurno() * 1.0 / $stat.getUkupnoPoteza() > 0.4 ) )
    $potez  : Potez( validan == true, vlasnikId == $pid, naSignurnoPlje == true, prioritet > 2 )
then
    modify( $potez ) { setPrioritet( 2 ) }
    System.out.println("[6.3] Historijski defanzivni obrazac potvrđen: sigurno polje figure " +
        $potez.getFiguraId() + " -> prioritet 2");
end

// 5.3: Vise od 2 kreirane blokade -> blokada dobija prioritet 3 cak i bez direktne prijetnje
rule "5.3: Blokade favorizovane - prioritet 3"
    salience 26
    no-loop true
when
    $stanje : StanjeIgre( preskaciPotez == false, $pid : aktivniIgracId )
    StatistikaIgraca( igracId == $pid, blokadeKreirane > 2 )
    $potez  : Potez( validan == true, vlasnikId == $pid,
                     prioritet > 3,
                     razlog contains "[kreira blokadu]" )
then
    modify( $potez ) { setPrioritet( 3 ) }
    System.out.println("[5.3] Blokade favorizovane: potez figure " + $potez.getFiguraId() + " -> prioritet 3");
end

// ============================================================
// SEKCIJA 5 — PRACENJE STATISTIKA IGRACA (salience -15 do -17)
// Fires after final selection (salience -10).
// VAZNO: Sva pravila koriste direktne Java setter pozive (bez modify/update)
// da bi sprijecila Drools re-evaluaciju i visestruko okidanje.
// StatistikaIgraca objekt se dijeli izmedju sesija, pa se vrijednosti akumuliraju
// automatski kroz vise KieSession poziva.
// ============================================================

rule "Stat: Broji potez"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( odabranaFiguraId != -1, $pid : aktivniIgracId )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setUkupnoPoteza( $stat.getUkupnoPoteza() + 1 );
end

rule "Stat: Broji sestice"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( odabranaFiguraId != -1, $pid : aktivniIgracId )
    $kocka  : IshodKocke( vrijednost == 6 )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setBrojSestica( $stat.getBrojSestica() + 1 );
end

rule "Stat: Uzastopne sestice max"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( odabranaFiguraId != -1, $pid : aktivniIgracId )
    $kocka  : IshodKocke( $uz : uzastopneSestice )
    $stat   : StatistikaIgraca( igracId == $pid, uzastopneSesticeMax < $uz )
then
    $stat.setUzastopneSesticeMax( $uz );
end

rule "Stat: Eliminacija izvedena"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId, $figId : odabranaFiguraId, odabranaFiguraId != -1 )
    $potez  : Potez( figuraId == $figId, vlasnikId == $pid, mozeEliminisati == true )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setEliminacijeIzvedene( $stat.getEliminacijeIzvedene() + 1 );
    System.out.println("[STAT] Igrac " + $pid + " eliminacija izvedena (ukupno: " + $stat.getEliminacijeIzvedene() + ")");
end

// Tracking from the victim's side: which player's piece gets eliminated this turn
rule "Stat: Eliminacija primljena"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId, $figId : odabranaFiguraId, odabranaFiguraId != -1 )
    $potez  : Potez( figuraId == $figId, vlasnikId == $pid, mozeEliminisati == true,
                     $targetAbs : novaApsolutnaPozicija )
    // Bind the owner of the piece being eliminated so it can match StatistikaIgraca
    $zrtva  : Figura( vlasnikId != $pid, status == StatusFigure.AKTIVNA,
                      apsolutnaPozicija == $targetAbs, sigurna == false,
                      $zrtvaId : vlasnikId )
    $stat   : StatistikaIgraca( igracId == $zrtvaId )
then
    $stat.setEliminacijePrimljene( $stat.getEliminacijePrimljene() + 1 );
    System.out.println("[STAT] Igrac " + $zrtvaId + " eliminacija primljena (ukupno: " + $stat.getEliminacijePrimljene() + ")");
end

rule "Stat: Bonus roll iskoristen"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( odabranaFiguraId != -1, bonusRoll == true, $pid : aktivniIgracId )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setBonusRollIskoristen( $stat.getBonusRollIskoristen() + 1 );
end

rule "Stat: Blokada kreirana"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId, $figId : odabranaFiguraId, odabranaFiguraId != -1 )
    $potez  : Potez( figuraId == $figId, vlasnikId == $pid,
                     razlog contains "[kreira blokadu]" )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setBlokadeKreirane( $stat.getBlokadeKreirane() + 1 );
    System.out.println("[STAT] Igrac " + $pid + " blokada kreirana (ukupno: " + $stat.getBlokadeKreirane() + ")");
end

rule "Stat: Potez na sigurno"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId, $figId : odabranaFiguraId, odabranaFiguraId != -1 )
    $potez  : Potez( figuraId == $figId, vlasnikId == $pid, naSignurnoPlje == true )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setPoteziNaSigurno( $stat.getPoteziNaSigurno() + 1 );
end

rule "Stat: Figura u cilju"
    salience -15
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId, $figId : odabranaFiguraId, odabranaFiguraId != -1 )
    $potez  : Potez( figuraId == $figId, vlasnikId == $pid,
                     novaRelativnaPozicija == BoardUtils.CILJ )
    $stat   : StatistikaIgraca( igracId == $pid )
then
    $stat.setFigureUCilju( $stat.getFigureUCilju() + 1 );
    System.out.println("[STAT] Igrac " + $pid + " figura u cilju! (ukupno: " + $stat.getFigureUCilju() + ")");
end

// Prosjecna udaljenost od cilja = prosjek (58 - relPos) za sve aktivne figure i figure u finalnoj stazi
rule "Stat: Prosjecna udaljenost od cilja"
    salience -16
    no-loop true
when
    $stanje : StanjeIgre( odabranaFiguraId != -1, $pid : aktivniIgracId )
    $stat   : StatistikaIgraca( igracId == $pid )
    $ukupnaUdaljenost : Double() from accumulate(
        $f : Figura( vlasnikId == $pid,
                     status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA,
                     $rp : relativnaPozicija ),
        sum( (double)(BoardUtils.CILJ - $rp) )
    )
    $brFigura : Long() from accumulate(
        $f2 : Figura( vlasnikId == $pid,
                      status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA ),
        count( $f2 )
    )
    eval( $brFigura > 0 )
then
    double prosjek = $ukupnaUdaljenost / $brFigura;
    $stat.azurirajProsjUdaljenost( prosjek );
end

// Mora biti zadnje statisticko pravilo — azurira stil igre na osnovu svih prethodnih direktnih upisa.
// Uvjet ukupnoPoteza > 0 se evaluira na pocetku sesije (Drools ne vidi direktne setter pozive kao promjenu).
// Na prvom potezu igraca (ukupnoPoteza==0) pravilo nece okidati; od drugog poteza nadalje okida ispravno.
rule "Stat: Azuriraj stil igre"
    salience -17
    no-loop true
when
    $stanje : StanjeIgre( odabranaFiguraId != -1, $pid : aktivniIgracId )
    $stat   : StatistikaIgraca( igracId == $pid, ukupnoPoteza > 0 )
then
    $stat.azurirajStilIgre();
    System.out.println("[STAT] Igrac " + $pid + ": " + $stat);
end

// ============================================================
// SEKCIJA 6.1 — BACKWARD CHAINING (salience 27 i -18)
// Query deklarise uslov nedostiznosti cilja.
// Pravila ga koriste unazad: ako ne postoji figura koja NE moze
// stici u cilj za N poteza, znaci da je cilj dostiziv za sve.
// ============================================================

// BC Query: figura koja NE moze doci do cilja za $maxPoteza poteza
// (minimalan broj poteza = ceil((CILJ - relPos) / 6))
query "figuraNijeNaDoseguCilja"( int $pid, int $maxPoteza )
    Figura( vlasnikId == $pid,
            status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA,
            $relPos : relativnaPozicija,
            eval( (BoardUtils.CILJ - $relPos + 5) / 6 > $maxPoteza ) )
end

// BC: Strateski izvjestaj — provjerava da li su sve figure dostizne u 10 poteza
// Fires after final selection (salience -10), serves as a strategic status report
rule "BC: Strateski cilj dostiziv za 10 poteza"
    salience -18
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    not figuraNijeNaDoseguCilja( $pid, 10; )
    exists Figura( vlasnikId == $pid,
                   status == StatusFigure.AKTIVNA || status == StatusFigure.FINALNA_STAZA )
then
    System.out.println("[BC] Strateski cilj dostiziv: sve figure igraca " + $pid +
        " mogu stici u cilj za 10 poteza!");
end

// ============================================================
// SEKCIJA 6.2 — COMPLEX EVENT PROCESSING (salience -20)
// Fires after final selection (salience -10) i BC izvjestaja (-18).
// Insertuje DogadjajIgre u radnu memoriju — CEP events u STREAM modu.
// Svaki event nosi timestamp (System.currentTimeMillis()) za vremensko uredjivanje.
// ============================================================

// CEP 1: Prijetnja eliminacijom — nasa nezasticena figura je u dosegu protivnika
// Fires once per threatened piece (not per threatening opponent pair — 'exists' handles dedup)
rule "CEP: Prijetnja eliminacijom"
    salience -20
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $nase   : Figura( vlasnikId == $pid, status == StatusFigure.AKTIVNA,
                      sigurna == false, $nasAbs : apsolutnaPozicija )
    exists Figura( vlasnikId != $pid, status == StatusFigure.AKTIVNA,
                   $protAbs : apsolutnaPozicija,
                   eval( BoardUtils.jeUDoseguZa( $nasAbs, $protAbs ) ) )
then
    DogadjajIgre d = new DogadjajIgre(TipDogadjaja.PRIJETNJA_ELIMINACIJOM,
                                       $pid, $nase.getId(), $nasAbs);
    insert( d );
    System.out.println("[CEP] " + d);
end

// CEP 2: Višestruke sestice — igrac je bacio sesticu >= 2 puta uzastopno
rule "CEP: Visestruke sestice"
    salience -20
    no-loop true
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    IshodKocke( vrijednost == 6, uzastopneSestice >= 2 )
then
    DogadjajIgre d = new DogadjajIgre(TipDogadjaja.VISESTRUKE_SESTICE, $pid, -1, -1);
    insert( d );
    System.out.println("[CEP] " + d);
end

// CEP 3: Protivnik blizu pobjede — protivnik ima >= 3 figure u finalnoj stazi
rule "CEP: Protivnik blizu pobjede"
    salience -20
    no-loop true
when
    $stanje  : StanjeIgre( $pid : aktivniIgracId )
    $brFinal : Long() from accumulate(
        $pf : Figura( vlasnikId != $pid, status == StatusFigure.FINALNA_STAZA ),
        count( $pf )
    )
    eval( $brFinal >= 3 )
then
    DogadjajIgre d = new DogadjajIgre(TipDogadjaja.PROTIVNIK_BLIZU_POBJEDE, $pid, -1, -1);
    insert( d );
    System.out.println("[CEP] " + d + " (" + $brFinal + " figura protivnika u finalnoj stazi)");
end

// CEP 4: Blokada protivnika na kljucnom polju (abs 40-52) — dvije iste protivnicke figure na jednom polju
rule "CEP: Blokada protivnika na kljucnom polju"
    salience -20
when
    $stanje : StanjeIgre( $pid : aktivniIgracId )
    $blok1  : Figura( vlasnikId != $pid, $protId : vlasnikId,
                      status == StatusFigure.AKTIVNA,
                      $absP : apsolutnaPozicija,
                      apsolutnaPozicija >= 40, apsolutnaPozicija <= 52 )
    exists   Figura( this != $blok1, vlasnikId == $protId,
                     status == StatusFigure.AKTIVNA,
                     apsolutnaPozicija == $absP )
then
    DogadjajIgre d = new DogadjajIgre(TipDogadjaja.BLOKADA_NA_KLJUCNOM_POLJU, $pid, -1, (int)$absP);
    insert( d );
    System.out.println("[CEP] " + d);
end
